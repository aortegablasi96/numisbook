# PostgreSQL connection string, used by the Next.js app and drizzle-kit.
# Copy this file to .env and adjust the values for your local database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/numisbook"

# Auth.js (NextAuth v5). Generate a secret with: npx auth secret
AUTH_SECRET=""
# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# OpenAI API key for the collection assistant (https://platform.openai.com).
# Without it, the /assistant feature returns 503; the rest of the app works.
OPENAI_API_KEY=""

# Object storage for coin images (S3-compatible; targets Cloudflare R2).
# When all four required vars are set, image bytes are stored in the bucket;
# otherwise the app falls back to local-filesystem storage under ./.storage
# (dev convenience — bytes are never stored in Postgres either way).
# R2: Cloudflare dashboard → R2 → Manage R2 API Tokens.
R2_ENDPOINT=""          # e.g. https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_REGION="auto"        # optional; R2 uses "auto"

# Foreign-exchange rates for multi-currency portfolio figures (ADR-007).
# Rates come from the European Central Bank via frankfurter.app — no API key
# needed. Set FX_API_URL only to point at a self-hosted/mirror endpoint;
# otherwise the public frankfurter.app API is used. Fetched rates are cached in
# the fx_rates table, so conversion still works offline once warmed.
FX_API_URL=""           # optional; defaults to https://api.frankfurter.app
