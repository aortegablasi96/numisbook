# NumisBook — production environment inventory (ADR-012)
#
# This is a NON-SECRET reference listing every variable a production deployment
# needs. Do NOT put real values here or commit them anywhere — set them in the
# Vercel project (Settings → Environment Variables) and, for migrations, in the
# GitHub "production" Environment. See docs/deployment.md for the full runbook.
#
# Legend: [required] must be set for production to work; [optional] has a safe
# default.

# ─── Database (Neon) ────────────────────────────────────────────────────────
# [required] App runtime connection. In production the app reads PROD_DATABASE_URL
# (falling back to DATABASE_URL). Use the Neon POOLED endpoint (host contains
# "-pooler") so serverless functions share connections. Always append
# ?sslmode=require.
PROD_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/numisbook?sslmode=require"

# NOTE: migrations use a SEPARATE connection — the Neon DIRECT (unpooled)
# endpoint — and it is NOT set here. It is stored as the GitHub Actions secret
# MIGRATION_DATABASE_URL in the "production" Environment (the migrate job in
# .github/workflows/ci.yml reads it). PgBouncer's pooled endpoint breaks DDL.

# ─── Authentication (Auth.js v5 + Google OAuth) ─────────────────────────────
# [required] Generate fresh for production: npx auth secret
AUTH_SECRET=""
# [required] Production OAuth client (Google Cloud Console → Credentials).
# Add the production redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# [required] Canonical production URL (custom domain or *.vercel.app), no
# trailing slash — e.g. https://numisbook.example.com
AUTH_URL=""

# ─── Object storage (Cloudflare R2) ─────────────────────────────────────────
# [required in production] Coin image/invoice bytes live in object storage. The
# local-filesystem fallback does NOT persist on Vercel's ephemeral filesystem,
# so all four R2 vars MUST be set in production. See ADR-004/005.
R2_ENDPOINT=""          # https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_REGION="auto"        # [optional] R2 uses "auto"

# ─── Collection assistant (OpenAI) ──────────────────────────────────────────
# [required for /assistant] Without it the assistant route returns 503; the rest
# of the app works.
OPENAI_API_KEY=""

# ─── Foreign-exchange rates (ADR-007) ───────────────────────────────────────
# [optional] Defaults to the public frankfurter.app API; set only to point at a
# self-hosted/mirror endpoint.
FX_API_URL=""

# ─── Logging (ADR-011) ──────────────────────────────────────────────────────
# [optional] Default from NODE_ENV: production → JSON at the "info" level.
LOG_LEVEL=""            # debug | info | warn | error
LOG_FORMAT=""           # json | pretty

# NODE_ENV is set to "production" by Vercel automatically — do not set it here.
